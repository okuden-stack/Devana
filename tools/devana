import sys
import argparse
import logging
import time
from pathlib import Path

# Import build system modules
from build_system import (
    # Configuration
    load_components_config,
    load_product_config,
    apply_profile,

    # Components
    discover_component_sources,
    discover_idl_files,

    # Dependencies
    resolve_dependencies,

    # Validation
    validate_all_components,
    check_system_requirements,

    # Generation
    generate_main_cmake,
    generate_component_cmake,

    # Building
    setup_build,
    build_project,
    clean_build,
    clean_all,
    run_app,

    # Packaging
    create_package,

    # Headers
    add_headers_to_directory,

    # IDL Compiler
    compile_idl,
    compile_all_idl,

    # Logging
    setup_logging,
    get_logger,

    # Terminal UI
    Banner,
    StatusLine,
    Table,
    Icon,
    Color,
    format_duration,
)

# ═══════════════════════════════════════════════════════════════════════════
# Path Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Script is in tools/ directory, so ROOT_DIR is parent
TOOLS_DIR = Path(__file__).resolve().parent
ROOT_DIR = TOOLS_DIR.parent
BUILD_DIR = ROOT_DIR / "build"
SRC_DIR = ROOT_DIR / "src"
CONFIG_DIR = TOOLS_DIR / "config"
TOPICS_DIR = ROOT_DIR / "topics"
LOGS_DIR = ROOT_DIR / "logs"
PACKAGE_DIR = ROOT_DIR / "packages"

COMPONENTS_CONFIG = CONFIG_DIR / "components.json"
PRODUCT_CONFIG = CONFIG_DIR / "product.json"

# ═══════════════════════════════════════════════════════════════════════════
# Command Implementations
# ═══════════════════════════════════════════════════════════════════════════

def cmd_build(args) -> bool:
    logger = get_logger(__name__)
    start_time = time.time()

    try:
        print(f"\n{Color.CYAN}{'═' * 70}{Color.RESET}")
        print(f"{Color.CYAN}{Color.BOLD}{'BUILD PROCESS':^70}{Color.RESET}")
        print(f"{Color.CYAN}{'═' * 70}{Color.RESET}")

        print(f"\n{Color.BRIGHT_BLUE}{Icon.MAGNIFY} {Color.BOLD}Loading Configuration{Color.RESET}")
        print(f"{Color.DIM}{'─' * 70}{Color.RESET}")
        logger.info("Loading configuration...")
        product_config = load_product_config(PRODUCT_CONFIG)
        component_configs = load_components_config(COMPONENTS_CONFIG)

        if args.profile:
            print(f"{Color.CYAN}{Icon.BULLET}{Color.RESET} Profile: {Color.BOLD}{args.profile.upper()}{Color.RESET}")
            component_configs = apply_profile(
                args.profile,
                component_configs,
                COMPONENTS_CONFIG
            )

        print(f"\n{Color.BRIGHT_BLUE}{Icon.MAGNIFY} {Color.BOLD}Discovering Components{Color.RESET}")
        print(f"{Color.DIM}{'─' * 70}{Color.RESET}")
        logger.info("Scanning component directories...")
        components = [discover_component_sources(c) for c in component_configs]
        print(f"{Color.GREEN}{Icon.CHECK}{Color.RESET} Found {Color.BOLD}{len(components)}{Color.RESET} components")

        components, dep_errors = resolve_dependencies(components)
        if dep_errors:
            for error in dep_errors:
                logger.warning(error)
            if any('Circular dependency' in e for e in dep_errors):
                return False

        if not validate_all_components(components):
            return False

        idl_files = []
        if product_config.idl_enabled:
            idl_files = discover_idl_files(TOPICS_DIR)
            if idl_files:
                print(f"{Color.CYAN}{Icon.BULLET}{Color.RESET} IDL topics: {Color.BOLD}{len(idl_files)}{Color.RESET}")

        buildtype = "debug" if args.debug else "release"

        # Always generate missing component cmake files
        for comp in components:
            comp_cmake = comp.path / "CMakeLists.txt"
            if not comp_cmake.exists():
                generate_component_cmake(comp)

        if args.regen or not (ROOT_DIR / "CMakeLists.txt").exists():
            print(f"\n{Color.BRIGHT_BLUE}{Icon.FILE} {Color.BOLD}Generating Build Files{Color.RESET}")
            print(f"{Color.DIM}{'─' * 70}{Color.RESET}")
            logger.info("Generating build files...")
            for comp in components:
                generate_component_cmake(comp)

            generate_main_cmake(
                components,
                product_config,
                ROOT_DIR / "CMakeLists.txt"
            )

            print(f"{Color.GREEN}{Icon.CHECK}{Color.RESET} Generated build files for {Color.BOLD}{len(components)}{Color.RESET} components")

        if not BUILD_DIR.exists() or not (BUILD_DIR / "CMakeCache.txt").exists() or not (BUILD_DIR / "Makefile").exists() or args.regen:
            if not setup_build(BUILD_DIR, buildtype):
                return False

        if not build_project(BUILD_DIR, args.jobs):
            return False

        elapsed = time.time() - start_time
        print(f"\n{Color.GREEN}{'═' * 70}{Color.RESET}")
        print(f"{Color.GREEN}{Color.BOLD}{Icon.SPARKLES} BUILD SUCCESSFUL {Icon.SPARKLES}{Color.RESET}")
        print(f"{Color.GREEN}{'═' * 70}{Color.RESET}")
        print(f"{Color.BRIGHT_GREEN}{Icon.CLOCK}{Color.RESET} Total time: {Color.BOLD}{format_duration(elapsed)}{Color.RESET}")
        print(f"{Color.BRIGHT_CYAN}{Icon.ROCKET}{Color.RESET} Executable: {Color.CYAN}{BUILD_DIR / product_config.output_name}{Color.RESET}")
        print()

        return True

    except Exception as e:
        logger = get_logger(__name__)
        print(f"\n{Color.RED}{'═' * 70}{Color.RESET}")
        print(f"{Color.RED}{Color.BOLD}{Icon.ERROR} BUILD FAILED{Color.RESET}")
        print(f"{Color.RED}{'═' * 70}{Color.RESET}")
        logger.error(f"Build failed: {e}")
        if args.verbose:
            import traceback
            logger.debug(traceback.format_exc())
        print()
        return False


def cmd_rebuild(args) -> bool:
    logger = get_logger(__name__)
    start_time = time.time()

    print(f"\n{Color.YELLOW}{'═' * 70}{Color.RESET}")
    print(f"{Color.YELLOW}{Color.BOLD}{'REBUILD FROM SCRATCH':^70}{Color.RESET}")
    print(f"{Color.YELLOW}{'═' * 70}{Color.RESET}\n")

    print(f"{Color.BRIGHT_YELLOW}{Icon.WARNING}{Color.RESET} {Color.BOLD}This will remove all build artifacts and rebuild everything{Color.RESET}\n")

    logger.info("Rebuilding project...")
    clean_build(BUILD_DIR)

    args.regen = True
    result = cmd_build(args)

    if result:
        total_time = time.time() - start_time
        print(f"{Color.BRIGHT_GREEN}{Icon.SPARKLES}{Color.RESET} Rebuild completed in {Color.BOLD}{format_duration(total_time)}{Color.RESET}\n")

    return result


def cmd_clean(args) -> bool:
    return clean_all(BUILD_DIR, LOGS_DIR)


def cmd_run(args) -> bool:
    product_config = load_product_config(PRODUCT_CONFIG)
    return run_app(BUILD_DIR, product_config)


def cmd_info(args) -> bool:
    product_config = load_product_config(PRODUCT_CONFIG)
    component_configs = load_components_config(COMPONENTS_CONFIG)
    components = [discover_component_sources(c) for c in component_configs]
    idl_files = discover_idl_files(TOPICS_DIR) if product_config.idl_enabled else []

    Banner.show(
        title=product_config.display_name,
        version=product_config.version,
        subtitle=product_config.description
    )

    info_headers = ["Setting", "Value"]
    info_rows = [
        ["Product", product_config.name],
        ["Version", product_config.version],
        ["Root Directory", str(ROOT_DIR)],
        ["Build Directory", str(BUILD_DIR)],
        ["Config Directory", str(CONFIG_DIR)],
        ["C++ Standard", product_config.cpp_standard],
        ["Components", str(len(components))],
        ["IDL Topics", str(len(idl_files))],
    ]

    print(f"\n{Color.BOLD}{Icon.TARGET} Project Configuration{Color.RESET}\n")
    print(Table.format(info_headers, info_rows))

    if components:
        print(f"\n{Color.BOLD}{Icon.PACKAGE} Enabled Components{Color.RESET}\n")
        comp_headers = ["Name", "Type", "Qt", "Sources", "Dependencies"]
        comp_rows = []
        for comp in components:
            qt_status = f"{Color.GREEN}{Icon.CHECK}{Color.RESET}" if comp.has_qt else f"{Color.DIM}-{Color.RESET}"
            deps = ", ".join(comp.depends_on[:2])
            if len(comp.depends_on) > 2:
                deps += f" +{len(comp.depends_on) - 2}"
            comp_rows.append([
                comp.name,
                comp.comp_type,
                qt_status,
                str(len(comp.sources)),
                deps if deps else "-"
            ])
        print(Table.format(comp_headers, comp_rows))

    print()
    return True


def cmd_package(args, format_type: str) -> bool:
    product_config = load_product_config(PRODUCT_CONFIG)
    return create_package(format_type, BUILD_DIR, PACKAGE_DIR, product_config)


def cmd_doctor(args) -> bool:
    return check_system_requirements()


def cmd_add_headers(args) -> bool:
    product_config = load_product_config(PRODUCT_CONFIG)
    updated, skipped = add_headers_to_directory(
        src_dir=SRC_DIR,
        author=args.author if hasattr(args, 'author') and args.author else "AK",
        project=product_config.display_name
    )
    return True


def cmd_compile_idl(args) -> bool:
    logger = get_logger(__name__)

    logger.info("Compiling IDL files to C++ headers...")
    logger.info(f"   Topics directory: {TOPICS_DIR}")
    logger.info(f"   Output directory: {SRC_DIR / 'topics'}")
    logger.info("")

    if hasattr(args, 'idl_file') and args.idl_file:
        idl_path = Path(args.idl_file)
        if not idl_path.is_absolute():
            idl_path = TOPICS_DIR / idl_path

        verbose = args.verbose if hasattr(args, 'verbose') else False
        success, message = compile_idl(idl_path, SRC_DIR / "topics", verbose)

        if success:
            logger.info(f"Generated: {message}")
            return True
        else:
            logger.error(f"Compilation failed: {message}")
            return False
    else:
        verbose = args.verbose if hasattr(args, 'verbose') else False
        success_count, fail_count, errors = compile_all_idl(
            TOPICS_DIR,
            SRC_DIR / "topics",
            verbose
        )

        logger.info("")
        logger.info("Compilation Summary:")
        logger.info(f"   Successful: {success_count}")
        logger.info(f"   Failed:     {fail_count}")

        if errors:
            logger.info("")
            logger.info("Errors:")
            for error in errors:
                logger.error(f"   {error}")

        return fail_count == 0


