def show_help():
    Banner.show(
        title="Devana Build System",
        version="1.0.0",
        subtitle="AI-Powered Multi-Domain Threat Defense — Configuration-driven CMake"
    )

    print(f"{Color.BOLD}{Icon.ROCKET} Usage{Color.RESET}\n")
    print(f"  {Color.CYAN}./devana{Color.RESET} {Color.YELLOW}<command>{Color.RESET} {Color.DIM}[options]{Color.RESET}\n")

    print(f"{Color.BOLD}{Icon.WRENCH} Commands{Color.RESET}\n")

    commands = [
        ["build", "Build the project incrementally"],
        ["rebuild", "Clean and rebuild from scratch"],
        ["clean", "Remove build artifacts and logs"],
        ["run", "Build and run the application"],
        ["info", "Show project configuration and components"],
        ["doctor", "Check system requirements and dependencies"],
        ["", ""],
        ["compile-idl", "Compile IDL files to C++ headers"],
        ["add-headers", "Add headers to source files"],
        ["", ""],
        ["package-deb", "Generate Debian/Ubuntu package"],
        ["package-rpm", "Generate Fedora/RHEL package"],
        ["package-arch", "Generate Arch Linux package"],
    ]

    for cmd, desc in commands:
        if cmd:
            print(f"  {Color.CYAN}{cmd:15}{Color.RESET} {desc}")
        else:
            print()

    print(f"\n{Color.BOLD}{Icon.TARGET} Options{Color.RESET}\n")

    options = [
        ["--profile <n>", "Build profile: minimal, standard, full"],
        ["--debug", "Debug build with symbols"],
        ["--release", "Release build (default)"],
        ["--jobs, -j <N>", "Number of parallel build jobs"],
        ["--verbose, -v", "Verbose output with debug logs"],
        ["--regen", "Force regenerate build files"],
        ["--author <n>", "Author name for file headers (default: AK)"],
        ["--idl-file <file>", "Specific IDL file to compile"],
        ["--help, -h", "Show this help message"],
    ]

    for opt, desc in options:
        print(f"  {Color.YELLOW}{opt:22}{Color.RESET} {desc}")

    print(f"\n{Color.BOLD}{Icon.SPARKLES} Examples{Color.RESET}\n")

    examples = [
        ("./devana build", "Standard incremental build"),
        ("./devana build --profile minimal", "Build with minimal components"),
        ("./devana build --debug --jobs 8", "Debug build with 8 parallel jobs"),
        ("./devana rebuild", "Clean build from scratch"),
        ("./devana info", "Show project information"),
        ("./devana doctor", "Verify system dependencies"),
        ("./devana package-deb", "Create Debian package"),
    ]

    max_len = max(len(ex) for ex, _ in examples)

    for example, desc in examples:
        padding = max_len - len(example)
        print(f"  {Color.DIM}${Color.RESET} {Color.CYAN}{example}{Color.RESET}{' ' * padding} {Color.DIM}# {desc}{Color.RESET}")

    print(f"\n{Color.DIM}For more information: Aleksandr K{Color.RESET}\n")


def parse_arguments():
    if '-h' in sys.argv or '--help' in sys.argv:
        show_help()
        sys.exit(0)

    parser = argparse.ArgumentParser(
        description="Devana Build System v1.0",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        add_help=False
    )

    parser.add_argument(
        "command",
        choices=["build", "rebuild", "clean", "run", "info", "doctor",
                "package-deb", "package-rpm", "package-arch", "add-headers",
                "compile-idl"],
        help="Command to execute"
    )

    parser.add_argument("--profile", choices=["minimal", "standard", "full"])
    parser.add_argument("--debug", action="store_true")
    parser.add_argument("--release", action="store_true")
    parser.add_argument("--jobs", "-j", type=int)
    parser.add_argument("--verbose", "-v", action="store_true")
    parser.add_argument("--author", type=str, default="AK")
    parser.add_argument("--idl-file", type=str)
    parser.add_argument("--regen", action="store_true")

    return parser.parse_args()


def main():
    args = parse_arguments()

    log_level = logging.DEBUG if args.verbose else logging.INFO
    setup_logging(LOGS_DIR, log_level, args.command)
    logger = get_logger(__name__)

    logger.info("=" * 70)
    logger.info("Devana Build System v1.0")
    logger.info("=" * 70)
    logger.info(f"Working directory: {ROOT_DIR}")
    logger.info(f"Configuration: {CONFIG_DIR}")

    commands = {
        "build": cmd_build,
        "rebuild": cmd_rebuild,
        "clean": cmd_clean,
        "run": cmd_run,
        "info": cmd_info,
        "doctor": cmd_doctor,
        "add-headers": cmd_add_headers,
        "compile-idl": cmd_compile_idl,
        "package-deb": lambda a: cmd_package(a, 'deb'),
        "package-rpm": lambda a: cmd_package(a, 'rpm'),
        "package-arch": lambda a: cmd_package(a, 'arch'),
    }

    try:
        success = commands[args.command](args)

        if success is False:
            logger.error(f"Command '{args.command}' failed")
            sys.exit(1)
        else:
            logger.info(f"Command '{args.command}' completed successfully")

    except FileNotFoundError as e:
        logger.error(f"Configuration error: {e}")
        logger.info(f"Make sure {CONFIG_DIR} exists with valid components.json and product.json")
        sys.exit(1)
    except Exception as e:
        logger.error(f"Unexpected error: {e}")
        if args.verbose:
            import traceback
            logger.debug(traceback.format_exc())
        sys.exit(1)


if __name__ == "__main__":
    main()
