# ─────────────────────────────────────────────────────────────────────────────
# env.local.zsh.example
#
# Copy this to env.local.zsh and fill in your values.
# This file is gitignored — it never leaves your machine.
#
#   cp tools/scripts/setup/env.local.zsh.example \
#      tools/scripts/setup/env.local.zsh
# ─────────────────────────────────────────────────────────────────────────────

# ── Home server SSH config ────────────────────────────────────────────────────
# Used by tools/scripts/sync-server.sh

# Hostname or IP of your Arch Linux build server
export DEVANA_DEPLOY_HOST="homeserver"

# SSH user on the remote machine
export DEVANA_DEPLOY_USER="aleks"

# SSH port (default 22)
export DEVANA_DEPLOY_PORT="22"

# Path on the remote machine where the project lives
export DEVANA_DEPLOY_PATH="~/projects/devana"

# SSH key to use (default: ~/.ssh/id_ed25519)
# export DEVANA_DEPLOY_KEY="${HOME}/.ssh/id_ed25519"
