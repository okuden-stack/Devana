#!/usr/bin/env zsh
# Example local environment configuration for Devana
# Copy this to env.local.zsh and customize for your local setup
# env.local.zsh is gitignored and won't be committed

# Example: Override default build directory
# export DEVANA_BUILD_DIR="${DEVANA_ROOT}/build-custom"

# Example: Add custom aliases
# alias dbfast='devana build --no-cache --release'

# Example: Add local paths
# export PATH="/path/to/custom/tools:${PATH}"

# Example: Custom environment variables
# export DEVANA_DEV_MODE=1
# export DEVANA_LOG_LEVEL=DEBUG

# Example: Point to local ONNX Runtime install
# export ONNXRUNTIME_ROOT="/usr/local/onnxruntime"
# export CMAKE_PREFIX_PATH="${ONNXRUNTIME_ROOT}:${CMAKE_PREFIX_PATH}"
